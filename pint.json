{
    "preset": "laravel",
    "rules": {
        "declare_strict_types": true,
        "no_unused_imports": true,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "single_quote": true,
        "trailing_comma_in_multiline": true,
        "no_superfluous_phpdoc_tags": true,
        "phpdoc_align": {
            "align": "left"
        },
        "concat_space": {
            "spacing": "one"
        }
    },
    "exclude": [
        "bootstrap",
        "config",
        "database/migrations",
        "public",
        "storage"
    ],
    "notPath": [
        "routes/console.php",
        "routes/web.php",
        "tests/TestCase.php"
    ]
}
